			(13 15 31 29)
			(14 12 28 30)
			
			(11 17 21 27)
			(16 10 26 20)
			
			(21 23 29 27)
			(22 20 26 28)
			
			(19 13 29 23)
			(12 18 22 28)
			
			(11 13 19 17)
			(12 10 16 18)
			

        );
    }

    
);
 
