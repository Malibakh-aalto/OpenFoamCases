FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1;			// 0.1 for centimeters, 0.01 for milimeters

////////////// These are in inputs for generating blocks, and the rest is calculateds
//////////////
L_plate			1.1;		// length of plate
L_before		0.5;		// length before the plate
Height			0.5;		// height of domain
Nx1 			100;		// plate x number of cells
rx1				12;			// expansion ration of plate in x
Ny				150;			// number of cells in y direction
ry				100;			// expansion ratio in y direction 
/////////////////////////////////////////////////

x0 		#neg $L_before;			
x1 		0;				
x2 		$L_plate;			
y0 		0;
y1 		$Height;
z0 		-0.2;
z1 		0.2;

// first domain (the right one, plate)
Nx1		$Nx1;												// number of cells in the right region
Lx1		$L_plate;											// length of righ region
rx1		$rx1;												// expansion ratio of right region
qx1		#calc "pow($rx1,1.0/($Nx1 - 1))";					// common ratio of expansion sequence
ax1		#calc "$L_plate * ((1-$qx1) /(1-pow($qx1,$Nx1)) )";	// first term of geometric sequence

// second domain (the left domain block)
Lx2		$L_before;
rx2		#calc "1.0 / $rx1";
alpha	$ax1;
ax2		#calc "$alpha / $rx2";
qx2		#calc "($ax2 - $Lx2) / ($ax2 * $rx2 - $Lx2)";
Nx2		#calc " int(1.0 + log($rx2)/log($qx2) )";

// y direction domain characteristics
Ny		$Ny;
Ly		$Height;
ry		$ry;


vertices
(
	($x0 $y0 $z0)	// 0
	($x0 $y0 $z1)	// 1
	($x1 $y0 $z0)	// 2
	($x1 $y0 $z1)	// 3
	($x1 $y1 $z0)	// 4
	($x1 $y1 $z1)	// 5
	($x0 $y1 $z0)	// 6
	($x0 $y1 $z1)	// 7
	($x2 $y0 $z0)	// 8 
	($x2 $y0 $z1)	// 9
	($x2 $y1 $z0)	// 10
	($x2 $y1 $z1)	// 11
);

blocks
(
    hex (0 2 4 6 1 3 5 7) ($Nx2 $Ny 1) simpleGrading ($rx2 $ry 1)
	hex (2 8 10 4 3 9 11 5) ($Nx1 $Ny 1) simpleGrading ($rx1 $ry 1)

);

boundary
(
    inlet
    {
        type patch;
        faces
        (
			(0 1 7 6)
        );
    }
    outlet
    {
        type patch;
        faces
        (
			(8 10 11 9)
        );
    }
    plate
    {
        type wall;
        faces
        (
			(2 8 9 3)
        );
    }
	
    symmTop
    {
        type symmetryPlane;
        faces
        (
			(6 7 5 4)
			(4 5 11 10)
        );
    }
	
	symmBottom
    {
        type symmetryPlane;
        faces
        (
			(0 2 3 1)
        );
    }
		
    frontAndBack
    {
        type empty;
        faces
        (
            (0 6 4 2)
			(2 4 10 8)
			(1 3 5 7)
			(5 3 9 11)
        );
    }

	
);


