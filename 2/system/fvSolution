FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-06;
        relTol          0.1;
        smoother        GaussSeidel;
    }

    pFinal
    {
        $p;
        tolerance       1e-06;
        relTol          0;
    }

    // "(U|k|epsilon|omega|R|nuTilda).*"		// changed previous "(U|k|epsilon|omega|R|nuTilda).*"
	"(U|UFinal)"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-05;
        relTol          0;
    }
}

PIMPLE
{
    nCorrectors     1;			  // 
    nNonOrthogonalCorrectors 2;   // 
    pRefCell        0;			  // required by incompressibleFluid solver
    pRefValue       0;			  // required by incompressibleFluid solver
}


